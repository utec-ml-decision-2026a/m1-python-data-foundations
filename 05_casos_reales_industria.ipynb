    "---\n",
    "## 💳 Caso 1: Fintech — Detección de Fraude en Tiempo Real\n",
    "\n",
    "**Contexto:** Un banco digital procesa 50,000 transacciones/minuto. Necesita un sistema que clasifique transacciones en <5ms como `legítima` o `fraude`.\n",
    "\n",
    "**Solución:** Feature engineering ultrarrápido con estructuras nativas + scoring vectorizado con NumPy."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import time\n",
    "from collections import defaultdict, deque\n",
    "from dataclasses import dataclass, field\n",
    "from typing import Dict, List, Tuple\n",
    "\n",
    "# ── Estructuras del sistema de fraude ────────────────────────────────────\n",
    "@dataclass\n",
    "class Transaccion:\n",
    "    __slots__ = [\"id\", \"usuario_id\", \"monto\", \"pais\", \"categoria\",\n",
    "                 \"hora\", \"es_online\", \"timestamp\"]\n",
    "    id: str\n",
    "    usuario_id: str\n",
    "    monto: float\n",
    "    pais: str\n",
    "    categoria: str\n",
    "    hora: int           # 0-23\n",
    "    es_online: bool\n",
    "    timestamp: float\n",
    "\n",
    "\n",
    "class PerfilUsuario:\n",
    "    \"\"\"Mantiene estadísticas en línea por usuario para feature engineering.\"\"\"\n",
    "    __slots__ = [\"usuario_id\", \"_montos\", \"_paises\", \"_categorias\",\n",
    "                 \"_horas\", \"_n_transacciones\", \"_ultima_transaccion\"]\n",
    "\n",
    "    def __init__(self, usuario_id: str, ventana: int = 30):\n",
    "        self.usuario_id = usuario_id\n",
    "        self._montos = deque(maxlen=ventana)  # últimas N transacciones\n",
    "        self._paises = deque(maxlen=ventana)\n",
    "        self._categorias = deque(maxlen=ventana)\n",
    "        self._horas = deque(maxlen=ventana)\n",
    "        self._n_transacciones = 0\n",
    "        self._ultima_transaccion = 0.0\n",
    "\n",
    "    def actualizar(self, tx: Transaccion):\n",
    "        self._montos.append(tx.monto)\n",
    "        self._paises.append(tx.pais)\n",
    "        self._categorias.append(tx.categoria)\n",
    "        self._horas.append(tx.hora)\n",
    "        self._ultima_transaccion = tx.timestamp\n",
    "        self._n_transacciones += 1\n",
    "\n",
    "    def extraer_features(self, tx: Transaccion) -> Dict[str, float]:\n",
    "        \"\"\"Extrae features en tiempo real basados en el historial.\"\"\"\n",
    "        if len(self._montos) == 0:\n",
    "            return {\"monto_ratio\": 1.0, \"pais_nuevo\": 1.0,\n",
    "                    \"categoria_nueva\": 1.0, \"hora_inusual\": 0.0,\n",
    "                    \"tiempo_desde_ultima\": 9999.0, \"n_tx_historico\": 0.0}\n",
    "\n",
    "        montos_arr = np.array(self._montos)\n",
    "        media_monto = montos_arr.mean()\n",
    "        std_monto   = montos_arr.std() + 1e-8\n",
    "\n",
    "        paises_conocidos = set(self._paises)\n",
    "        cats_conocidas   = set(self._categorias)\n",
    "        horas_arr = np.array(self._horas)\n",
    "\n",
    "        return {\n",
    "            \"monto_zscore\":      (tx.monto - media_monto) / std_monto,\n",
    "            \"monto_ratio\":       tx.monto / (media_monto + 1e-8),\n",
    "            \"pais_nuevo\":        float(tx.pais not in paises_conocidos),\n",
    "            \"categoria_nueva\":   float(tx.categoria not in cats_conocidas),\n",
    "            \"hora_inusual\":      float(tx.hora not in range(\n",
    "                                    int(np.percentile(horas_arr, 10)),\n",
    "                                    int(np.percentile(horas_arr, 90)) + 1)),\n",
    "            \"tiempo_desde_ultima\": tx.timestamp - self._ultima_transaccion,\n",
    "            \"n_tx_historico\":    float(self._n_transacciones),\n",
    "        }\n",
    "\n",
    "\n",
    "class DetectorFraude:\n",
    "    \"\"\"Motor de scoring de fraude en tiempo real.\"\"\"\n",
    "\n",
    "    # Pesos del modelo (simulados — en prod vendrían de un modelo entrenado)\n",
    "    PESOS = np.array([0.35, 0.20, 0.15, 0.10, 0.10, -0.05, -0.05])\n",
    "    FEATURES = [\"monto_zscore\", \"monto_ratio\", \"pais_nuevo\",\n",
    "                \"categoria_nueva\", \"hora_inusual\",\n",
    "                \"tiempo_desde_ultima\", \"n_tx_historico\"]\n",
    "\n",
    "    def __init__(self, umbral: float = 0.6):\n",
    "        self.umbral = umbral\n",
    "        self._perfiles: Dict[str, PerfilUsuario] = {}\n",
    "        self._alertas: List[dict] = []\n",
    "\n",
    "    def _sigmoid(self, x: np.ndarray) -> np.ndarray:\n",
    "        return 1 / (1 + np.exp(-np.clip(x, -10, 10)))\n",
    "\n",
    "    def procesar(self, tx: Transaccion) -> Tuple[float, bool]:\n",
    "        # Obtener o crear perfil del usuario\n",
    "        if tx.usuario_id not in self._perfiles:\n",
    "            self._perfiles[tx.usuario_id] = PerfilUsuario(tx.usuario_id)\n",
    "\n",
    "        perfil = self._perfiles[tx.usuario_id]\n",
    "        features = perfil.extraer_features(tx)\n",
    "\n",
    "        # Vector de features\n",
    "        x = np.array([features[f] for f in self.FEATURES])\n",
    "\n",
    "        # Scoring lineal + sigmoid\n",
    "        score = float(self._sigmoid(np.dot(x, self.PESOS)))\n",
    "        es_fraude = score > self.umbral\n",
    "\n",
    "        if es_fraude:\n",
    "            self._alertas.append({\n",
    "                \"tx_id\": tx.id, \"usuario\": tx.usuario_id,\n",
    "                \"score\": round(score, 4), \"monto\": tx.monto,\n",
    "                \"features_top\": sorted(features.items(),\n",
    "                                       key=lambda x: abs(x[1]), reverse=True)[:3]\n",
    "            })\n",
    "\n",
    "        perfil.actualizar(tx)  # actualizar DESPUÉS de scoring\n",
    "        return score, es_fraude\n",
    "\n",
    "    @property\n",
    "    def alertas(self):\n",
    "        return self._alertas\n",
    "\n",
    "\n",
    "# ── Simulación de transacciones ───────────────────────────────────────────\n",
    "np.random.seed(42)\n",
    "detector = DetectorFraude(umbral=0.65)\n",
    "\n",
    "paises = [\"MX\", \"US\", \"CO\", \"AR\", \"BR\"]\n",
    "categorias = [\"supermercado\", \"restaurante\", \"gasolina\", \"online\", \"farmacia\"]\n",
    "\n",
    "transacciones = []\n",
    "for i in range(200):\n",
    "    # 10% de transacciones fraudulentas (montos anómalos, países nuevos)\n",
    "    es_anomala = (i % 10 == 0)\n",
    "    transacciones.append(Transaccion(\n",
    "        id=f\"TX{i:05d}\",\n",
    "        usuario_id=f\"USR{i % 20:03d}\",\n",
    "        monto=np.random.uniform(5000, 50000) if es_anomala else np.random.uniform(50, 500),\n",
    "        pais=np.random.choice([\"RU\", \"NG\"]) if es_anomala else np.random.choice(paises),\n",
    "        categoria=np.random.choice(categorias),\n",
    "        hora=np.random.randint(2, 5) if es_anomala else np.random.randint(8, 22),\n",
    "        es_online=es_anomala,\n",
    "        timestamp=time.time() + i * 60\n",
    "    ))\n",
    "\n",
    "# Procesar todas las transacciones\n",
    "t0 = time.time()\n",
    "resultados = [detector.procesar(tx) for tx in transacciones]\n",
    "tiempo_total = time.time() - t0\n",
    "\n",
    "scores = [r[0] for r in resultados]\n",
    "alertas_detectadas = sum(1 for r in resultados if r[1])\n",
    "\n",
    "print(f\"💳 Sistema de Detección de Fraude — Resultados:\")\n",
    "print(f\"   Transacciones procesadas: {len(transacciones):,}\")\n",
    "print(f\"   Tiempo total: {tiempo_total*1000:.1f}ms\")\n",
    "print(f\"   Tiempo promedio/tx: {tiempo_total/len(transacciones)*1000:.3f}ms\")\n",
    "print(f\"   Alertas generadas: {alertas_detectadas} ({alertas_detectadas/len(transacciones):.1%})\")\n",
    "print(f\"   Score promedio: {np.mean(scores):.4f}\")\n",
    "print(f\"\\nTop 3 alertas de fraude:\")\n",
    "for alerta in detector.alertas[:3]:\n",
    "    print(f\"   TX {alerta['tx_id']} | Score: {alerta['score']:.4f} \"\n",
    "          f\"| Monto: ${alerta['monto']:,.0f} | Usuario: {alerta['usuario']}\")\n",
    "    print(f\"   Features: {alerta['features_top'][:2]}\")"
   ]
  },

